# ── THREADS ──────────────────────────────────────────
# From Graph API Explorer → threads.net → Generate Threads Access Token
THREADS_TOKEN=your_short_lived_token_here

# From Meta Developer Portal → Thread Scraper app → App Settings → Basic → App Secret
THREADS_APP_SECRET=your_app_secret_here

# ── NOTION ───────────────────────────────────────────
# From notion.so/my-integrations → your integration → Internal Integration Secret
NOTION_TOKEN=secret_your_notion_token_here

# Your Threads Engagement Tracker database ID (already set for Christine)
NOTION_DB_ID=320ed5709c944f1ca3946bc2daccef5e

# ── SYNC SETTINGS ────────────────────────────────────
# How many posts to fetch per sync (max 100)
POSTS_LIMIT=50

# Cron schedule (default: every Monday at 9am)
# Examples:
#   0 9 * * 1   = Every Monday 9am
#   0 9 * * 0   = Every Sunday 9am
#   0 9 1 * *   = 1st of every month 9am
CRON_SCHEDULE=0 9 * * 1
